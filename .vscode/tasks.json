{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run NovaCast Web",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"--filter",
				"@novacast/web",
				"dev",
				"--host",
				"127.0.0.1",
				"--port",
				"3000"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Typecheck NovaCast",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"typecheck"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Build NovaCast",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"build"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}