<?xml version="1.0" encoding="utf-8" ?>
<component name="PlayerScreen" extends="Group">
  <interface>
    <field id="content" type="node" />
    <field id="action" type="string" alwaysNotify="true" />
  </interface>
  <script type="text/brightscript" uri="pkg:/components/PlayerScreen.brs" />

  <children>
    <!-- Video (no native UI — we build our own) -->
    <Video id="video" width="1920" height="1080"
           enableUI="false"
           enableTrickPlay="false" />

    <!-- Custom overlay (always on top of video) -->
    <Group id="overlay" visible="true">

      <!-- Top gradient -->
      <Rectangle id="topGrad" width="1920" height="160" color="0x000000CC" />

      <!-- Title bar -->
      <Label id="titleLabel" translation="[72,36]" width="1200"
             font="font:MediumBoldSystemFont" color="0xFFFFFFFF" text="" />
      <Label id="subtitleLabel" translation="[72,72]" width="1000"
             font="font:SmallSystemFont" color="0xA8B2CCDD" text="" />

      <!-- Bottom gradient -->
      <Rectangle id="bottomGrad" width="1920" height="220" translation="[0,860]" color="0x000000CC" />

      <!-- Progress bar area -->
      <Group id="progressGroup" translation="[72,910]">
        <!-- Time elapsed -->
        <Label id="timeElapsed" translation="[0,0]" width="100"
               font="font:SmallestSystemFont" color="0xFFFFFFCC" text="0:00" />

        <!-- Progress bar background -->
        <Rectangle id="progressBg" translation="[110,6]" width="1620" height="6"
                   color="0xFFFFFF33" />

        <!-- Buffered bar -->
        <Rectangle id="bufferedBar" translation="[110,6]" width="0" height="6"
                   color="0xFFFFFF55" />

        <!-- Progress bar fill -->
        <Rectangle id="progressFill" translation="[110,6]" width="0" height="6"
                   color="0x67E8F9FF" />

        <!-- Scrubber handle -->
        <Rectangle id="scrubber" translation="[106,0]" width="16" height="18"
                   color="0x67E8F9FF" />

        <!-- Time remaining -->
        <Label id="timeRemaining" translation="[1740,0]" width="110"
               font="font:SmallestSystemFont" color="0xFFFFFF99" text="0:00"
               horizAlign="right" />
      </Group>

      <!-- Control buttons row -->
      <Group id="controlsRow" translation="[0,960]">
        <!-- Rewind icon -->
        <Label id="rwLabel" translation="[780,10]"
               font="font:SmallSystemFont" color="0xFFFFFFAA" text="<< 10s" />

        <!-- Play/Pause -->
        <Rectangle id="playPauseBg" translation="[890,0]" width="140" height="40"
                   color="0x67E8F920" />
        <Label id="playPauseLabel" translation="[890,8]" width="140"
               font="font:SmallBoldSystemFont" color="0xFFFFFFFF" text="  PAUSE"
               horizAlign="center" />

        <!-- Fast Forward icon -->
        <Label id="ffLabel" translation="[1060,10]"
               font="font:SmallSystemFont" color="0xFFFFFFAA" text="10s >>" />
      </Group>

      <!-- Status indicator -->
      <Label id="statusLabel" translation="[860,500]" width="200"
             font="font:MediumBoldSystemFont" color="0x67E8F9FF" text=""
             horizAlign="center" visible="false" />

      <!-- Buffering spinner text -->
      <Label id="bufferingLabel" translation="[810,520]" width="300"
             font="font:SmallSystemFont" color="0xFFFFFFCC" text="Buffering..."
             horizAlign="center" visible="false" />

      <!-- Hint bar -->
      <Label id="hintLabel" translation="[72,1030]"
             font="font:SmallestSystemFont" color="0xFFFFFF44"
             text="OK: Play/Pause  |  <</>>/Left/Right: Seek  |  Back: Exit  |  *: Subtitles" />
    </Group>
  </children>
</component>
