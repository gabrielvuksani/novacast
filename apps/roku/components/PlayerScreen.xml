<?xml version="1.0" encoding="utf-8" ?>
<component name="PlayerScreen" extends="Group">
  <interface>
    <field id="content" type="node" />
    <field id="action" type="string" alwaysNotify="true" />
  </interface>
  <script type="text/brightscript" uri="pkg:/components/PlayerScreen.brs" />

  <children>
    <Video id="video" width="1920" height="1080"
           enableUI="false" enableTrickPlay="false" />

    <!-- Custom overlay -->
    <Group id="overlay" visible="true">

      <!-- Top: gradient + title -->
      <Rectangle width="1920" height="140" color="0x000000BB" />
      <Rectangle width="1920" height="60" translation="[0,140]" color="0x00000066" />
      <Label id="titleLabel" translation="[80,30]" width="1400"
             font="font:MediumBoldSystemFont" color="0xFFFFFFFF" text="" />
      <Label id="subtitleLabel" translation="[80,68]" width="1200"
             font="font:SmallSystemFont" color="0xA8B2CCCC" text="" />
      <Label translation="[1700,30]" text="NOVACAST" width="160"
             font="font:SmallestBoldSystemFont" color="0x67E8F955" horizAlign="right" />

      <!-- Bottom: controls area -->
      <Rectangle width="1920" height="180" translation="[0,900]" color="0x000000BB" />
      <Rectangle width="1920" height="40" translation="[0,860]" color="0x00000066" />

      <!-- Progress bar -->
      <Group id="progressGroup" translation="[80,920]">
        <Label id="timeElapsed" width="90" font="font:SmallestSystemFont"
               color="0xFFFFFFCC" text="0:00" />
        <Rectangle id="progressBg" translation="[100,5]" width="1640" height="5"
                   color="0xFFFFFF22" />
        <Rectangle id="bufferedBar" translation="[100,5]" width="0" height="5"
                   color="0xFFFFFF44" />
        <Rectangle id="progressFill" translation="[100,5]" width="0" height="5"
                   color="0x67E8F9FF" />
        <Rectangle id="scrubber" translation="[96,0]" width="14" height="15"
                   color="0x67E8F9FF" />
        <Label id="timeRemaining" translation="[1750,0]" width="100"
               font="font:SmallestSystemFont" color="0xFFFFFF88" text="-0:00"
               horizAlign="right" />
      </Group>

      <!-- Playback controls -->
      <Group id="controlsRow" translation="[0,960]">
        <Label translation="[680,8]" font="font:SmallSystemFont" color="0xFFFFFF66" text="<< 10s" />
        <Rectangle translation="[820,0]" width="280" height="40" color="0x67E8F918" />
        <Label id="playPauseLabel" translation="[820,8]" width="280"
               font="font:SmallBoldSystemFont" color="0xFFFFFFFF" text="  ||  PAUSE"
               horizAlign="center" />
        <Label translation="[1140,8]" font="font:SmallSystemFont" color="0xFFFFFF66" text="10s >>" />
      </Group>

      <!-- Control hints -->
      <Label translation="[80,1010]" font="font:SmallestSystemFont" color="0xFFFFFF33"
             text="OK Play/Pause  ·  Left/Right ±10s  ·  Up/Down ±30s  ·  * Subtitles  ·  Back Exit" />

      <!-- Center status -->
      <Label id="statusLabel" translation="[810,480]" width="300"
             font="font:LargeBoldSystemFont" color="0x67E8F9EE" text=""
             horizAlign="center" visible="false" />
      <Label id="bufferingLabel" translation="[810,530]" width="300"
             font="font:SmallSystemFont" color="0xFFFFFFBB" text="Buffering..."
             horizAlign="center" visible="false" />
    </Group>
  </children>
</component>
