<?xml version="1.0" encoding="utf-8" ?>
<component name="MainScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/MainScene.brs" />

  <children>
    <!-- Full background -->
    <Rectangle id="background" width="1920" height="1080" color="0x080C18FF" />

    <!-- ━━━ HEADER ━━━ -->
    <Group id="header" translation="[0,0]">
      <Rectangle width="1920" height="80" color="0x080C1800" />
      <Rectangle width="1920" height="1" translation="[0,79]" color="0xFFFFFF10" />
      <Label id="appTitle" translation="[72,22]" text="NovaCast" font="font:LargeBoldSystemFont" color="0x67E8F9FF" />
      <Label id="navLabel" translation="[300,30]" text="Loading..." font="font:SmallSystemFont" color="0x6B7A9EFF" />
      <Label id="clockLabel" translation="[1760,30]" text="" font="font:SmallSystemFont" color="0x6B7A9EFF" horizAlign="right" width="100" />
    </Group>

    <!-- ━━━ HOME ━━━ -->
    <Group id="homeScreen" visible="true" translation="[0,0]">
      <!-- Hero backdrop (full width, behind header) -->
      <Poster id="heroPoster" width="1920" height="580" translation="[0,0]" loadDisplayMode="scaleToZoom" opacity="0.6" />
      <Rectangle width="1920" height="580" color="0x080C18AA" />
      <Rectangle width="960" height="580" color="0x080C18DD" />
      <Rectangle width="1920" height="200" translation="[0,380]" color="0x080C18FF" opacity="0.98" />

      <!-- Hero content -->
      <Label id="heroType" translation="[72,320]" text="" font="font:SmallSystemFont" color="0x67E8F9CC" />
      <Label id="heroTitle" translation="[72,345]" width="860" text="NovaCast" font="font:LargeBoldSystemFont" color="0xFFFFFFFF" />
      <Label id="heroDesc" translation="[72,410]" width="760" text="Your universe of entertainment" font="font:SmallSystemFont" color="0xA8B2CCEE" maxLines="2" />
      <Label id="heroMeta" translation="[72,465]" text="" font="font:SmallSystemFont" color="0x67E8F9AA" />

      <!-- Content label -->
      <Label id="browseLabel" translation="[72,520]" text="TRENDING NOW" font="font:SmallBoldSystemFont" color="0xA8B2CC88" />

      <!-- Main poster grid -->
      <PosterGrid id="homeGrid" translation="[72,555]"
                  basePosterSize="[210,315]"
                  itemSpacing="[18,24]"
                  numColumns="8"
                  numRows="2"
                  caption1NumLines="1"
                  caption2NumLines="0"
                  caption1Color="0xFFFFFFDD"
                  caption2Color="0x6B7A9EFF"
                  focusBitmapBlendColor="0x67E8F940"
                  loadingBitmapBlendColor="0x67E8F920" />
    </Group>

    <!-- ━━━ DETAIL ━━━ -->
    <Group id="detailScreen" visible="false" translation="[0,0]">
      <Poster id="detailBg" width="1920" height="620" translation="[0,0]" loadDisplayMode="scaleToZoom" opacity="0.5" />
      <Rectangle width="1920" height="620" color="0x080C18BB" />
      <Rectangle width="1920" height="220" translation="[0,400]" color="0x080C18FF" opacity="0.98" />

      <Label id="detailType" translation="[72,340]" text="" font="font:SmallSystemFont" color="0x67E8F9CC" />
      <Label id="detailTitle" translation="[72,365]" width="920" text="" font="font:LargeBoldSystemFont" color="0xFFFFFFFF" />
      <Label id="detailMeta" translation="[72,430]" text="" font="font:SmallSystemFont" color="0x67E8F9AA" />
      <Label id="detailDesc" translation="[72,460]" width="860" text="" font="font:SmallSystemFont" color="0xA8B2CCEE" maxLines="3" />
      <Label id="detailGenres" translation="[72,530]" text="" font="font:SmallSystemFont" color="0x6B7A9E99" />

      <Label id="srcLabel" translation="[72,580]" text="SOURCES" font="font:SmallBoldSystemFont" color="0xA8B2CC88" />
      <LabelList id="sourceList" translation="[72,610]"
                 itemSize="[860,50]" itemSpacing="[0,4]"
                 focusedColor="0x67E8F9FF" color="0xA8B2CCCC"
                 focusBitmapBlendColor="0x67E8F920"
                 drawFocusFeedback="true" />
      <Label id="noSrcLabel" translation="[72,610]" text="Loading sources..." font="font:SmallSystemFont" color="0xF59E0BDD" visible="false" />
    </Group>

    <!-- ━━━ SEARCH RESULTS ━━━ -->
    <Group id="searchScreen" visible="false" translation="[0,80]">
      <Label id="searchHeading" translation="[72,24]" text="Search Results" font="font:LargeBoldSystemFont" color="0xFFFFFFFF" />
      <Label id="searchInfo" translation="[72,72]" text="" font="font:SmallSystemFont" color="0x6B7A9EFF" />
      <PosterGrid id="searchGrid" translation="[72,110]"
                  basePosterSize="[210,315]" itemSpacing="[18,24]"
                  numColumns="8" numRows="3"
                  caption1NumLines="1" caption2NumLines="1"
                  caption1Color="0xFFFFFFDD" caption2Color="0x6B7A9EFF"
                  focusBitmapBlendColor="0x67E8F940" />
    </Group>

    <!-- ━━━ SOURCES ━━━ -->
    <Group id="sourcesScreen" visible="false" translation="[0,80]">
      <Label id="sourcesHeading" translation="[72,24]" text="Sources" font="font:LargeBoldSystemFont" color="0xFFFFFFFF" />
      <Label id="sourcesSub" translation="[72,72]" text="Connected addons powering NovaCast" font="font:SmallSystemFont" color="0x6B7A9EFF" />
      <LabelList id="addonList" translation="[72,120]"
                 itemSize="[900,60]" itemSpacing="[0,6]"
                 focusedColor="0x67E8F9FF" color="0xA8B2CCCC"
                 focusBitmapBlendColor="0x67E8F920"
                 drawFocusFeedback="true" />
    </Group>

    <!-- ━━━ CUSTOM VIDEO PLAYER ━━━ -->
    <PlayerScreen id="playerScreen" visible="false" translation="[0,0]" />

    <!-- ━━━ BOTTOM BAR ━━━ -->
    <Rectangle width="1920" height="36" translation="[0,1044]" color="0x080C18EE" />
    <Rectangle width="1920" height="1" translation="[0,1044]" color="0xFFFFFF08" />
    <Label id="hintText" translation="[72,1050]" text="OK Select  ·  Back Return  ·  * Search  ·  Options Sources" font="font:SmallestSystemFont" color="0x6B7A9E88" />
  </children>
</component>
