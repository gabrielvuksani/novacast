<?xml version="1.0" encoding="utf-8" ?>
<component name="MainScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/MainScene.brs" />

  <children>
    <Rectangle id="bg" width="1920" height="1080" color="0x0A0E1AFF" />
    <Rectangle id="bgGlow1" width="800" height="600" translation="[0,0]" color="0x67E8F908" />
    <Rectangle id="bgGlow2" width="600" height="400" translation="[1320,680]" color="0x8B7CFF06" />

    <!-- HOME SCREEN -->
    <Group id="homeScreen" visible="true">
      <!-- Hero area -->
      <Poster id="heroPoster" width="1920" height="540" loadDisplayMode="scaleToZoom" opacity="0.55" />
      <Rectangle width="1920" height="540" color="0x0A0E1A00" />
      <Rectangle width="1100" height="540" color="0x0A0E1ACC" />
      <Rectangle width="1920" height="260" translation="[0,280]" color="0x0A0E1AFF" opacity="0.95" />

      <!-- Top bar -->
      <Group id="topBar" translation="[80,28]">
        <Label id="logoLabel" text="NOVACAST" font="font:SmallBoldSystemFont" color="0x67E8F9AA" />
        <Rectangle width="88" height="3" translation="[0,24]" color="0x67E8F966" />

        <!-- Tab bar -->
        <Label id="tabHome" translation="[120,0]" text="Home" font="font:SmallBoldSystemFont" color="0xFFFFFFFF" />
        <Label id="tabLive" translation="[220,0]" text="Live TV" font="font:SmallBoldSystemFont" color="0x6B7A9EAA" />
        <Label id="tabSports" translation="[340,0]" text="Sports" font="font:SmallBoldSystemFont" color="0x6B7A9EAA" />
      </Group>

      <!-- Hero text content -->
      <Group id="heroContent" translation="[80,200]">
        <Label id="heroType" text="" font="font:SmallestSystemFont" color="0x67E8F9CC" width="200" />
        <Label id="heroTitle" translation="[0,22]" text="NovaCast" width="850"
               font="font:LargeBoldSystemFont" color="0xFFFFFFFF" />
        <Label id="heroDesc" translation="[0,85]" text="Your universe of entertainment"
               width="700" font="font:SmallSystemFont" color="0xB0B8CCDD" maxLines="2" />
        <Label id="heroMeta" translation="[0,140]" text=""
               font="font:SmallestSystemFont" color="0x67E8F999" />
        <Rectangle translation="[0,175]" width="200" height="36" color="0x67E8F918" />
        <Label translation="[16,183]" text="Press OK to view" width="180"
               font="font:SmallestBoldSystemFont" color="0x67E8F9CC" />
      </Group>

      <!-- Status bar -->
      <Group id="statusBar" translation="[80,390]">
        <Label id="statusLabel" text="Loading..." font="font:SmallestSystemFont"
               color="0x6B7A9ECC" width="600" />
      </Group>

      <!-- Section label -->
      <Label id="sectionLabel" translation="[80,420]" text="TRENDING"
             font="font:SmallestBoldSystemFont" color="0x67E8F966" />
      <Rectangle width="64" height="2" translation="[80,440]" color="0x67E8F933" />

      <!-- Content grid -->
      <PosterGrid id="homeGrid" translation="[80,460]"
                  basePosterSize="[195,293]"
                  itemSpacing="[14,20]"
                  numColumns="9"
                  numRows="2"
                  caption1NumLines="1"
                  caption2NumLines="0"
                  caption1Color="0xE0E4EECC"
                  caption2Color="0x6B7A9EFF"
                  focusBitmapBlendColor="0x67E8F945"
                  loadingBitmapBlendColor="0x67E8F915" />
    </Group>

    <!-- LIVE TV SCREEN -->
    <Group id="liveScreen" visible="false">
      <Rectangle width="1920" height="1080" color="0x0A0E1AFF" />
      <Label translation="[80,32]" text="BACK" font="font:SmallestBoldSystemFont" color="0x6B7A9EAA" />

      <Group translation="[80,70]">
        <Rectangle width="10" height="24" color="0xEF4444FF" />
        <Label translation="[20,0]" text=" LIVE TV" font="font:MediumBoldSystemFont" color="0xFFFFFFFF" />
        <Label id="liveCount" translation="[200,4]" text=""
               font="font:SmallestSystemFont" color="0x6B7A9ECC" />
      </Group>

      <Label translation="[80,110]" text="Live channels and sports from your connected sources"
             font="font:SmallestSystemFont" color="0x6B7A9ECC" />

      <PosterGrid id="liveGrid" translation="[80,150]"
                  basePosterSize="[280,158]"
                  itemSpacing="[14,16]"
                  numColumns="6"
                  numRows="5"
                  caption1NumLines="1"
                  caption2NumLines="1"
                  caption1Color="0xE0E4EECC"
                  caption2Color="0x6B7A9EFF"
                  focusBitmapBlendColor="0xEF444445"
                  loadingBitmapBlendColor="0xEF444415" />
    </Group>

    <!-- DETAIL SCREEN -->
    <Group id="detailScreen" visible="false">
      <Poster id="detailBg" width="1920" height="1080" loadDisplayMode="scaleToZoom" opacity="0.35" />
      <Rectangle width="1920" height="1080" color="0x0A0E1ABB" />
      <Rectangle width="1100" height="1080" color="0x0A0E1ADD" />

      <Label translation="[80,32]" text="BACK" font="font:SmallestBoldSystemFont" color="0x6B7A9EAA" />

      <Poster id="detailPoster" translation="[80,100]" width="240" height="360"
              loadDisplayMode="scaleToZoom" />

      <Group id="detailInfo" translation="[360,100]">
        <Label id="detailType" text="" font="font:SmallestSystemFont" color="0x67E8F9CC" width="200" />
        <Label id="detailTitle" translation="[0,20]" width="700"
               font="font:LargeBoldSystemFont" color="0xFFFFFFFF" text="" />
        <Label id="detailMeta" translation="[0,82]" text=""
               font="font:SmallestSystemFont" color="0x67E8F999" width="600" />
        <Label id="detailDesc" translation="[0,110]" width="650"
               font="font:SmallSystemFont" color="0xA8B2CCDD" maxLines="4" text="" />
        <Label id="detailGenres" translation="[0,200]" text=""
               font="font:SmallestSystemFont" color="0x6B7A9E88" width="600" />
      </Group>

      <Group id="sourcesSection" translation="[80,500]">
        <Label text="AVAILABLE SOURCES" font="font:SmallestBoldSystemFont" color="0x67E8F966" />
        <Rectangle translation="[0,20]" width="100" height="2" color="0x67E8F933" />

        <LabelList id="sourceList" translation="[0,35]"
                   itemSize="[1000,48]" itemSpacing="[0,4]"
                   focusedColor="0x67E8F9FF" color="0xA8B2CCBB"
                   focusBitmapBlendColor="0x67E8F920"
                   drawFocusFeedback="true" />

        <Label id="noSrcLabel" translation="[0,35]" text="Loading sources..."
               font="font:SmallSystemFont" color="0xF59E0BCC" visible="false" />
      </Group>
    </Group>

    <!-- SEARCH SCREEN -->
    <Group id="searchScreen" visible="false">
      <Rectangle width="1920" height="1080" color="0x0A0E1AFF" />
      <Label translation="[80,32]" text="BACK" font="font:SmallestBoldSystemFont" color="0x6B7A9EAA" />
      <Label id="searchHeading" translation="[80,70]" text="SEARCH RESULTS"
             font="font:SmallestBoldSystemFont" color="0x67E8F966" />
      <Rectangle width="100" height="2" translation="[80,90]" color="0x67E8F933" />
      <Label id="searchInfo" translation="[80,105]" text=""
             font="font:SmallestSystemFont" color="0x6B7A9ECC" />
      <PosterGrid id="searchGrid" translation="[80,140]"
                  basePosterSize="[195,293]" itemSpacing="[14,20]"
                  numColumns="9" numRows="3"
                  caption1NumLines="1" caption2NumLines="1"
                  caption1Color="0xE0E4EECC" caption2Color="0x6B7A9EFF"
                  focusBitmapBlendColor="0x67E8F945" />
    </Group>

    <!-- SOURCES SCREEN -->
    <Group id="sourcesScreen" visible="false">
      <Rectangle width="1920" height="1080" color="0x0A0E1AFF" />
      <Label translation="[80,32]" text="BACK" font="font:SmallestBoldSystemFont" color="0x6B7A9EAA" />
      <Label translation="[80,70]" text="CONNECTED SOURCES"
             font="font:SmallestBoldSystemFont" color="0x67E8F966" />
      <Rectangle width="120" height="2" translation="[80,90]" color="0x67E8F933" />
      <Label translation="[80,108]" text="Addons powering your NovaCast experience"
             font="font:SmallestSystemFont" color="0x6B7A9ECC" />
      <LabelList id="addonList" translation="[80,145]"
                 itemSize="[1000,56]" itemSpacing="[0,6]"
                 focusedColor="0x67E8F9FF" color="0xA8B2CCBB"
                 focusBitmapBlendColor="0x67E8F920"
                 drawFocusFeedback="true" />
    </Group>

    <!-- CUSTOM PLAYER -->
    <PlayerScreen id="playerScreen" visible="false" />

    <!-- BOTTOM BAR -->
    <Group id="bottomBar">
      <Rectangle width="1920" height="32" translation="[0,1048]" color="0x0A0E1AEE" />
      <Rectangle width="1920" height="1" translation="[0,1048]" color="0xFFFFFF06" />
      <Label id="hintText" translation="[80,1053]"
             text="OK Select  -  Back Return  -  Replay Search  -  Options Sources"
             font="font:SmallestSystemFont" color="0x6B7A9E66" />
    </Group>
  </children>
</component>
