{
  "rootDir": ".",
  "stagingDir": "./out/staging",
  "outFile": "./out/novacast.zip",
  "createPackage": true,
  "files": [
    "manifest",
    "source/**/*.brs",
    "components/**/*.xml",
    "components/**/*.brs",
    "images/**/*.png",
    "images/**/*.jpg"
  ],
  "diagnosticSeverityOverrides": {
